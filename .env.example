# SmartFilter Environment Configuration Template
# Copy this to .env and fill in your Telegram credentials

# Telegram Alert Configuration
# Get these from Telegram Bot API:
# - BOT_TOKEN: From @BotFather (Create a bot, get token)
# - CHAT_ID: Send a message to your bot, then get: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# SmartFilter Configuration
CYCLE_SLEEP=60              # Seconds between cycles
DRY_RUN=false               # Set to true to test without sending signals
DEBUG_FILTERS=false         # Set to true for verbose filter logging

# NOTE: KuCoin API credentials NOT needed!
# SmartFilter uses ONLY public KuCoin REST endpoints:
# - OHLCV (candles): https://api.kucoin.com/api/v1/market/candles
# - Orderbook: https://api.kucoin.com/api/v1/market/orderbook/level2_*
# - No authentication required - public data only
